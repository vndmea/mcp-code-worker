{
  "name": "@mcp-code-worker/cli",
  "version": "0.1.0",
  "description": "MCP Code Worker CLI for controlled host-worker workflows over local repositories.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "cw": "./dist/main.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "package.json"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsup",
    "prepare:publish": "node ./scripts/prepare-publish.mjs",
    "prepack": "pnpm --dir ../.. --filter @mcp-code-worker/cli... build && pnpm run prepare:publish",
    "pack:publish": "pnpm run prepack && npm pack .publish --json",
    "publish:npm": "pnpm run prepack && npm publish .publish --access public"
  },
  "dependencies": {
    "@mcp-code-worker/core": "workspace:*",
    "@mcp-code-worker/graph": "workspace:*",
    "@mcp-code-worker/mcp-server": "workspace:*",
    "@mcp-code-worker/models": "workspace:*",
    "@mcp-code-worker/tools": "workspace:*",
    "@ai-sdk/openai": "^3.0.74",
    "@langchain/langgraph": "^1.4.5",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@commander-js/extra-typings": "^15.0.0",
    "ai": "^6.0.209",
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "zod": "^4.1.12"
  },
  "publishConfig": {
    "access": "public"
  }
}
