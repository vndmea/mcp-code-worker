{
  "version": 1,
  "leaderModel": {
    "provider": "mock",
    "model": "gpt-5.4"
  },
  "workerModel": {
    "provider": "openai-compatible",
    "model": "deepseek-v4-flash",
    "baseURL": "https://api.deepseek.com"
  },
  "safety": {
    "dryRun": true,
    "allowWrite": false,
    "allowedCommands": [
      "git",
      "node",
      "pnpm"
    ]
  },
  "context": {
    "maxFileBytes": 20000,
    "maxTotalBytes": 120000,
    "ignoredPaths": [
      "node_modules",
      ".git",
      "dist",
      "build",
      "coverage",
      ".turbo",
      ".next"
    ]
  },
  "sessions": {
    "retentionDays": 30,
    "maxStoredSessions": 100
  }
}
