{
  "name": "agent-orchestrator",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript agent orchestration server for multi-model engineering workflows via CLI and MCP.",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run",
    "smoke": "vitest run packages/cli/src/smoke.test.ts",
    "smoke:dist": "pnpm build && vitest run packages/cli/src/smoke-dist.test.ts",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "dev:playground": "pnpm --filter @agent-orchestrator/playground dev",
    "example:leader-worker-basic": "pnpm --filter @agent-orchestrator/example-leader-worker-basic dev"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^26.0.0",
    "eslint": "^9.39.4",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^2.1.9"
  }
}
