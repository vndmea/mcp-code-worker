{
  "name": "mcp-code-worker",
  "version": "0.1.0",
  "private": true,
  "description": "Controlled execution runtime for multi-model engineering workflows via CLI and MCP.",
  "type": "module",
  "packageManager": "pnpm@11.9.0",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "changeset": "changeset",
    "prepare": "husky",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --exclude packages/cli/src/smoke-pack.test.ts --exclude packages/cli/src/smoke-dist.test.ts",
    "smoke": "vitest run packages/cli/src/smoke.test.ts",
    "smoke:pack": "pnpm --filter @mcp-code-worker/cli... build && vitest run packages/cli/src/smoke-pack.test.ts",
    "smoke:dist": "pnpm build && vitest run packages/cli/src/smoke-dist.test.ts",
    "release:check": "pnpm build && pnpm smoke:pack && pnpm smoke:dist",
    "version:packages": "changeset version",
    "release:npm": "pnpm release:check && pnpm --dir packages/cli run publish:npm",
    "test:watch": "vitest --exclude packages/cli/src/smoke-pack.test.ts --exclude packages/cli/src/smoke-dist.test.ts",
    "lint": "eslint .",
    "format": "prettier --check .",
    "format:write": "prettier --write .",
    "dev:playground": "pnpm --filter @mcp-code-worker/playground dev",
    "example:host-worker-basic": "pnpm --filter @mcp-code-worker/example-host-worker-basic dev"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^26.0.0",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "prettier": "^3.8.4",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.0",
    "vitest": "^2.1.9"
  }
}
